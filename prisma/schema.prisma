generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Better Auth — https://www.better-auth.com/docs/adapters/prisma
model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime

  /// Whether the user has completed the onboarding flow.
  onboardingCompleted Boolean @default(false)
  /// Preferred language code (e.g. "en", "ar", "fr").
  preferredLanguage   String?

  sessions           Session[]
  accounts           Account[]
  scrapedContexts    ScrapedContext[]
  generatedCreatives GeneratedCreative[]
  chatConversations  ChatConversation[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

/// Site-level context (one row per scrape target / brand)
model ScrapedContext {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Hostname only, e.g. confirmix.com
  baseUrl   String
  name      String

  logo            String?
  primaryColor    String?
  secondaryColor  String?
  ogImage         String?
  /// Array of [{fontfamily, body, heading}] entries from page evaluation.
  typography      Json?
  /// AI-derived personality specs.
  personality     Json?
  /// AI-derived marketing angles (up to 40 strings).
  marketingAngles Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subcontexts SubContext[]
  documents   ContextDocument[]

  @@unique([userId, baseUrl])
  @@map("context")
}

model SubContext {
  id        String   @id @default(cuid())
  contextId String
  context   ScrapedContext @relation(fields: [contextId], references: [id], onDelete: Cascade)

  /// Normalized path, e.g. / or /login
  path      String
  title     String

  documents ContextDocument[]

  @@unique([contextId, path])
  @@map("sub_context")
}

model ContextDocument {
  id           String   @id @default(cuid())
  contextId    String
  context      ScrapedContext @relation(fields: [contextId], references: [id], onDelete: Cascade)
  subcontextId String
  subcontext   SubContext @relation(fields: [subcontextId], references: [id], onDelete: Cascade)

  section String
  content String @db.Text

  /// Vector from OpenAI `text-embedding-3-small` (JSON array of floats, dim 1536).
  embedding Json?

  /// Same embedding as `embedding`, stored for pgvector similarity search (cosine via `<=>`).
  embeddingVector Unsupported("vector(1536)")? @map("embedding_vector")

  documentImages ContextDocumentImage[]
  documentVideos ContextDocumentVideo[]

  @@map("context_document")
}

/// One row per image URL linked to a scraped document section.
model ContextDocumentImage {
  id         String          @id @default(cuid())
  documentId String
  document   ContextDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  url        String          @db.Text
  sortOrder  Int             @default(0)

  @@map("context_document_image")
}

/// One row per video URL linked to a scraped document section.
model ContextDocumentVideo {
  id         String          @id @default(cuid())
  documentId String
  document   ContextDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  url        String          @db.Text
  sortOrder  Int             @default(0)

  @@map("context_document_video")
}

/// A chat conversation (thread of messages).
model ChatConversation {
  id        String                 @id @default(cuid())
  userId    String
  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String                 @default("New chat")
  messages  ChatPersistedMessage[]
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  @@map("chat_conversation")
}

/// One message inside a chat conversation.
model ChatPersistedMessage {
  id                 String           @id @default(cuid())
  conversationId     String
  conversation       ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  /// "user" | "assistant"
  role               String

  text               String?          @db.Text
  imageUrl           String?          @db.Text
  aspectRatio        String?
  contextId          String?
  contextName        String?

  /// JSON array of image URLs used as reference.
  referenceImageUrls Json?

  createdAt          DateTime         @default(now())

  @@map("chat_persisted_message")
}

/// A generated ad creative image saved to Cloudflare R2.
model GeneratedCreative {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// The ScrapedContext (DNA profile) used to generate this creative.
  contextId String

  /// Cloudflare R2 object key — used for deletion.
  r2Key     String   @db.Text

  /// Public CDN URL of the WebP image stored in R2.
  imageUrl  String   @db.Text

  /// Template / format label (e.g. "Facebook Feed 1:1").
  templateLabel String

  /// Aspect ratio string (e.g. "1:1", "9:16").
  aspectRatio   String

  /// Headline used in the prompt.
  headline      String

  /// Optional subheadline.
  subheadline   String?

  /// The full image-model prompt that was sent.
  prompt        String   @db.Text

  createdAt DateTime @default(now())

  @@map("generated_creative")
}

