generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Better Auth — https://www.better-auth.com/docs/adapters/prisma
model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  sessions         Session[]
  accounts         Account[]
  scrapedContexts  ScrapedContext[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

/// Site-level context (one row per scrape target / brand)
model ScrapedContext {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Hostname only, e.g. confirmix.com
  baseUrl   String
  name      String

  /// Extra branding payload (personality, favicon, og, full font stacks, etc.)
  branding  Json?

  logo            String?
  primaryColor    String?
  secondaryColor  String?
  /// Font-weight summary, e.g. "body:400 · heading:600"
  typography      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subcontexts SubContext[]
  documents   ContextDocument[]

  @@unique([userId, baseUrl])
  @@map("context")
}

model SubContext {
  id        String   @id @default(cuid())
  contextId String
  context   ScrapedContext @relation(fields: [contextId], references: [id], onDelete: Cascade)

  /// Normalized path, e.g. / or /login
  path      String
  title     String

  documents ContextDocument[]

  @@unique([contextId, path])
  @@map("sub_context")
}

model ContextDocument {
  id           String   @id @default(cuid())
  contextId    String
  context      ScrapedContext @relation(fields: [contextId], references: [id], onDelete: Cascade)
  subcontextId String
  subcontext   SubContext @relation(fields: [subcontextId], references: [id], onDelete: Cascade)

  section String
  content String @db.Text
  images  String[] @default([])
  videos  String[] @default([])

  @@map("context_document")
}
