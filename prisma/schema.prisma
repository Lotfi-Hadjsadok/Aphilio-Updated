generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Better Auth — https://www.better-auth.com/docs/adapters/prisma
model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime

  /// Whether the user has completed the onboarding flow.
  onboardingCompleted Boolean @default(false)
  /// Current onboarding wizard step (0 welcome, 1 URL, 2 language, 3 scrape). Reset when completed.
  onboardingStep      Int     @default(0)
  /// URL entered during onboarding; used to resume the scrape step after refresh.
  onboardingDraftUrl  String? @db.Text
  /// Preferred language code (e.g. "en", "ar", "fr").
  preferredLanguage   String?

  /// Polar customer id (UUID) — same as `customers.get` / customer state `id`.
  polarCustomerId       String? @map("polar_customer_id")
  /// Cached balance for the Aphilio credits meter stored as integer units (Polar balance × 100).
  /// e.g. 78.5 credits → 7850. Divide by 100 to get the display value.
  aphilioCreditsBalance Int @default(0) @map("aphilio_credits_balance")
  /// Whether the user currently has at least one active Polar subscription; kept in sync via webhooks.
  hasActiveSubscription Boolean @default(false) @map("has_active_subscription")
  /// Last known Polar subscription status (active, trialing, canceled, unpaid, …). Not cleared when a sub ends; null only before first sync.
  polarSubscriptionStatus            String?   @map("polar_subscription_status")
  /// End of the current billing period from Polar (`current_period_end`).
  polarSubscriptionCurrentPeriodEnd  DateTime? @map("polar_subscription_current_period_end")
  /// When the subscription access ends (`ends_at`), if set; e.g. scheduled cancellation.
  polarSubscriptionEndsAt            DateTime? @map("polar_subscription_ends_at")
  /// When false (default), image generation is blocked if cached credits are insufficient. When true, local balance may go negative until Polar sync.
  allowCreditOverage Boolean @default(false) @map("allow_credit_overage")
  /// When overage is allowed: max local debt in stored units (same scale as balance); null = no cap on how negative balance may go.
  maxCreditOverageStoredUnits Int? @map("max_credit_overage_stored_units")

  sessions           Session[]
  accounts           Account[]
  scrapedContexts           ScrapedContext[]
  generatedCreatives        GeneratedCreative[]
  chatConversations         ChatConversation[]
  adCreativeStudioSessions  AdCreativeStudioSession[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

/// Site-level context (one row per scrape target / brand)
model ScrapedContext {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Hostname only, e.g. confirmix.com
  baseUrl   String
  name      String

  logo            String?
  /// Public favicon URL validated at scrape time (same pipeline as logo).
  favicon         String?
  primaryColor    String?
  secondaryColor  String?
  ogImage         String?
  /// Array of [{fontfamily, body, heading}] entries from page evaluation.
  typography      Json?
  /// AI-derived personality specs.
  personality     Json?
  /// AI-derived marketing angles (up to 40 strings).
  marketingAngles Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subcontexts SubContext[]
  documents   ContextDocument[]

  @@unique([userId, baseUrl])
  @@map("context")
}

model SubContext {
  id        String   @id @default(cuid())
  contextId String
  context   ScrapedContext @relation(fields: [contextId], references: [id], onDelete: Cascade)

  /// Normalized path, e.g. / or /login
  path      String
  title     String

  documents ContextDocument[]

  @@unique([contextId, path])
  @@map("sub_context")
}

model ContextDocument {
  id           String   @id @default(cuid())
  contextId    String
  context      ScrapedContext @relation(fields: [contextId], references: [id], onDelete: Cascade)
  subcontextId String
  subcontext   SubContext @relation(fields: [subcontextId], references: [id], onDelete: Cascade)

  section String
  content String @db.Text

  /// Vector from OpenAI `text-embedding-3-small` (JSON array of floats, dim 1536).
  embedding Json?

  /// Same embedding as `embedding`, stored for pgvector similarity search (cosine via `<=>`).
  embeddingVector Unsupported("vector(1536)")? @map("embedding_vector")

  documentImages ContextDocumentImage[]
  documentVideos ContextDocumentVideo[]

  @@map("context_document")
}

/// One row per image URL linked to a scraped document section.
model ContextDocumentImage {
  id         String          @id @default(cuid())
  documentId String
  document   ContextDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  url        String          @db.Text
  sortOrder  Int             @default(0)

  @@map("context_document_image")
}

/// One row per video URL linked to a scraped document section.
model ContextDocumentVideo {
  id         String          @id @default(cuid())
  documentId String
  document   ContextDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  url        String          @db.Text
  sortOrder  Int             @default(0)

  @@map("context_document_video")
}

/// A chat conversation (thread of messages).
model ChatConversation {
  id        String                 @id @default(cuid())
  userId    String
  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String                 @default("New chat")
  messages  ChatPersistedMessage[]
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  @@map("chat_conversation")
}

/// One message inside a chat conversation.
model ChatPersistedMessage {
  id                 String           @id @default(cuid())
  conversationId     String
  conversation       ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  /// "user" | "assistant"
  role               String

  text               String?          @db.Text
  imageUrl           String?          @db.Text
  aspectRatio        String?
  contextId          String?
  contextName        String?

  /// JSON array of image URLs used as reference.
  referenceImageUrls Json?

  createdAt          DateTime         @default(now())

  @@map("chat_persisted_message")
}

/// One saved run through Ad studio (steps 1–4); supports resume and history search.
model AdCreativeStudioSession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  contextId String

  /// Shown in history and used for text search.
  title            String @default("Ad studio session")
  contextNameCache String @default("")

  /// Step the user last had open (2 = angles, 3 = formats, 4 = image grid).
  activeStep   Int @default(2)
  /// Highest step with completed saved data.
  furthestStep Int @default(2)

  selectedAngles    Json?
  /// Snapshot for step 2: similar docs + reference groups (SelectAngleState ready fields).
  angleStepData     Json?
  sectionIds        Json?
  selectedTemplates Json?
  prompts           Json?
  /// Array aligned with prompts: pending | success | error per layout slot.
  slotOutcomes      Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  generatedCreatives GeneratedCreative[]

  @@index([userId, updatedAt(sort: Desc)])
  @@index([userId, contextId])
  @@map("ad_creative_studio_session")
}

/// A generated ad creative image saved to Cloudflare R2.
model GeneratedCreative {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// The ScrapedContext (DNA profile) used to generate this creative.
  contextId String

  /// Optional link to the Ad studio session and slot index (partial runs).
  studioSessionId String?
  studioSession   AdCreativeStudioSession? @relation(fields: [studioSessionId], references: [id], onDelete: SetNull)
  slotIndex       Int?

  /// Cloudflare R2 object key — used for deletion.
  r2Key     String   @db.Text

  /// Public CDN URL of the WebP image stored in R2.
  imageUrl  String   @db.Text

  /// Template / format label (e.g. "Facebook Feed 1:1").
  templateLabel String

  /// Aspect ratio string (e.g. "1:1", "9:16").
  aspectRatio   String

  /// Headline used in the prompt.
  headline      String

  /// Optional subheadline.
  subheadline   String?

  /// The full image-model prompt that was sent.
  prompt        String   @db.Text

  createdAt DateTime @default(now())

  @@index([studioSessionId])
  @@map("generated_creative")
}

