# PostgreSQL (required for Better Auth persistence)
DATABASE_URL=postgres://user:password@localhost:5432/your_db

# openssl rand -base64 32
BETTER_AUTH_SECRET=

# App URL (server-side redirects, OAuth — becomes .../api/auth for callbacks)
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Public site URL — Open Graph, Twitter cards, sitemap, and robots use this when set (falls back to BETTER_AUTH_URL, then VERCEL_URL).
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Analytics 4 — Measurement ID from GA Admin → Data streams (format G-XXXXXXXXXX)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=

OPENAI_API_KEY=

GOOGLE_API_KEY=


# Cloudflare R2 — https://dash.cloudflare.com/?to=/:account/r2
# Create a bucket, then generate API tokens with Object Read & Write permissions.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=



# Polar: token + product IDs must come from the SAME mode (sandbox vs production).
# Use an Organization Access Token (OAT), e.g. polar_oat_... — not a customer/session token.
# Default is sandbox. Use POLAR_SERVER=production only with a production OAT.
POLAR_SERVER=sandbox
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=        # From Polar webhook config
POLAR_PRODUCT_ID_MONTHLY=    # Aphilio Monthly ($39)
POLAR_PRODUCT_ID_YEARLY=     # Aphilio Yearly ($20)
# UUIDs of the Polar `meter_credit` benefits for each plan (sync `aphilioCreditsBalance`).
POLAR_APHILIO_CREDITS_ID_MONTHLY=
POLAR_APHILIO_CREDITS_ID_YEARLY=

# Ad image generation: credits per successful image (ingested as Polar event `credit_usage`, metadata key `credit`).
APHILIO_CREDIT_COST_FAST=1
APHILIO_CREDIT_COST_PREMIUM=1.5